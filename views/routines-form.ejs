<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= action === 'create' ? 'Nueva Rutina' : 'Editar Rutina' %> | Apolo</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/a2d9d6bd3c.js" crossorigin="anonymous"></script>
    <style>
        :root {
            --color-dark-bg: #0a0e12;
            --color-dark-secondary: #12181f;
            --color-gold: #b8996e;
            --color-gold-light: #c9a97a;
            --color-gold-dim: #8a7252;
            --color-light-text: #b8bcc4;
            --color-gray: #6b7280;
            --color-gray-light: #8b92a0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            background: #000000;
            color: var(--color-light-text);
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .page-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            min-height: 100vh;
            background: 
                radial-gradient(circle at 10% 20%, rgba(184, 153, 110, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(184, 153, 110, 0.05) 0%, transparent 40%),
                linear-gradient(135deg, rgba(10, 14, 18, 0.98), rgba(18, 24, 31, 0.95));
            padding: 30px 50px;
        }
        
        /* HEADER */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
            padding: 25px 30px;
            background: rgba(18, 24, 31, 0.6);
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            backdrop-filter: blur(10px);
            animation: slideDown 0.6s ease;
        }
        
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .header-left {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .back-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 24px;
            background: linear-gradient(135deg, rgba(184, 153, 110, 0.2), rgba(184, 153, 110, 0.1));
            border: 1px solid var(--color-gold-dim);
            border-radius: 12px;
            color: var(--color-gold);
            text-decoration: none;
            font-weight: 600;
            letter-spacing: 0.05em;
            transition: all 0.3s ease;
        }
        
        .back-btn:hover {
            background: linear-gradient(135deg, rgba(184, 153, 110, 0.3), rgba(184, 153, 110, 0.2));
            border-color: var(--color-gold);
            transform: translateX(-5px);
            box-shadow: 0 5px 20px rgba(184, 153, 110, 0.3);
        }
        
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            color: var(--color-gold);
            letter-spacing: 0.1em;
            text-shadow: 0 0 20px rgba(184, 153, 110, 0.5);
        }
        
        /* FORM */
        .form-container {
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.7), rgba(10, 14, 18, 0.9));
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            padding: 40px;
            animation: fadeInUp 0.6s ease 0.3s both;
        }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-bottom: 25px;
        }
        
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .form-group.full-width {
            grid-column: 1 / -1;
        }
        
        .form-label {
            color: var(--color-gold);
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.05em;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .form-label i {
            font-size: 1rem;
        }
        
        .form-input,
        .form-select,
        .form-textarea {
            padding: 14px 18px;
            background: rgba(18, 24, 31, 0.6);
            border: 1px solid var(--color-gold-dim);
            border-radius: 12px;
            color: var(--color-light-text);
            font-size: 0.95rem;
            font-family: 'Montserrat', sans-serif;
            transition: all 0.3s ease;
        }
        
        .form-input:focus,
        .form-select:focus,
        .form-textarea:focus {
            outline: none;
            border-color: var(--color-gold);
            box-shadow: 0 0 20px rgba(184, 153, 110, 0.3);
            background: rgba(18, 24, 31, 0.8);
        }
        
        .form-textarea {
            resize: vertical;
            min-height: 120px;
        }
        
        .form-select {
            cursor: pointer;
        }
        
        .form-hint {
            color: var(--color-gray-light);
            font-size: 0.85rem;
            font-style: italic;
        }
        
        /* TIPO CARDS */
        .tipo-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 25px;
        }
        
        .tipo-card {
            position: relative;
        }
        
        .tipo-card input[type="radio"] {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }
        
        .tipo-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            padding: 20px;
            background: rgba(18, 24, 31, 0.6);
            border: 2px solid var(--color-gold-dim);
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }
        
        .tipo-card input[type="radio"]:checked + .tipo-label {
            background: rgba(184, 153, 110, 0.2);
            border-color: var(--color-gold);
            box-shadow: 0 5px 20px rgba(184, 153, 110, 0.3);
        }
        
        .tipo-label:hover {
            border-color: var(--color-gold);
            transform: translateY(-3px);
        }
        
        .tipo-icon {
            font-size: 2rem;
            color: var(--color-gold);
        }
        
        .tipo-name {
            color: var(--color-light-text);
            font-weight: 600;
            font-size: 0.9rem;
        }
        
        /* NIVEL SELECTOR */
        .nivel-selector {
            display: flex;
            gap: 15px;
        }
        
        .nivel-option {
            flex: 1;
            position: relative;
        }
        
        .nivel-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            cursor: pointer;
        }
        
        .nivel-label {
            display: block;
            padding: 12px;
            background: rgba(18, 24, 31, 0.6);
            border: 2px solid var(--color-gold-dim);
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
            color: var(--color-light-text);
        }
        
        .nivel-option input[type="radio"]:checked + .nivel-label {
            background: rgba(184, 153, 110, 0.2);
            border-color: var(--color-gold);
            color: var(--color-gold);
        }
        
        .nivel-label:hover {
            border-color: var(--color-gold);
            transform: translateY(-2px);
        }
        
        /* FORM ACTIONS */
        .form-actions {
            display: flex;
            gap: 15px;
            padding-top: 30px;
            border-top: 1px solid var(--color-gold-dim);
        }
        
        .btn-cancel {
            flex: 1;
            padding: 14px;
            background: rgba(184, 153, 110, 0.1);
            border: 1px solid var(--color-gold-dim);
            border-radius: 12px;
            color: var(--color-gold);
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            text-decoration: none;
            text-align: center;
            display: inline-block;
        }
        
        .btn-cancel:hover {
            background: rgba(184, 153, 110, 0.2);
            border-color: var(--color-gold);
            transform: translateY(-2px);
        }
        
        .btn-submit {
            flex: 2;
            padding: 14px;
            background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold));
            border: none;
            border-radius: 12px;
            color: #000;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        
        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(184, 153, 110, 0.5);
            background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
        }
        
        /* RESPONSIVE */
        @media (max-width: 768px) {
            .page-wrapper {
                padding: 20px;
            }
            
            .page-header {
                flex-direction: column;
                gap: 20px;
            }
            
            .header-left {
                flex-direction: column;
                width: 100%;
            }
            
            .page-title {
                font-size: 2rem;
            }
            
            .form-container {
                padding: 25px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .tipo-cards {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .nivel-selector {
                flex-direction: column;
            }
            
            .form-actions {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="page-wrapper">
        <!-- HEADER -->
        <div class="page-header">
            <div class="header-left">
                <a href="/routines" class="back-btn">
                    <i class="fas fa-arrow-left"></i>
                    Volver
                </a>
                <h1 class="page-title">
                    <i class="fas fa-<%= action === 'create' ? 'plus' : 'edit' %>"></i>
                    <%= action === 'create' ? 'Nueva Rutina' : 'Editar Rutina' %>
                </h1>
            </div>
        </div>
        
        <!-- FORM -->
        <form action="/routines/<%= action === 'create' ? 'create' : routine.id + '/edit' %>" method="POST" class="form-container">
            <!-- Información Básica -->
            <div class="form-grid">
                <div class="form-group full-width">
                    <label class="form-label">
                        <i class="fas fa-tag"></i>
                        Nombre de la Rutina
                    </label>
                    <input 
                        type="text" 
                        name="nombre" 
                        class="form-input" 
                        value="<%= routine ? routine.nombre : '' %>"
                        placeholder="Ej: Dia de Pecho, Movilidad..." 
                        required
                    >
                </div>
                
                <div class="form-group full-width">
                    <label class="form-label">
                        <i class="fas fa-align-left"></i>
                        Descripción
                    </label>
                    <textarea 
                        name="descripcion" 
                        class="form-textarea" 
                        placeholder="Describe tu rutina: objetivos, enfoque, beneficios..."
                    ><%= routine ? routine.descripcion : '' %></textarea>
                </div>
            </div>
            
            <!-- Tipo de Entrenamiento -->
            <div class="form-group full-width">
                <label class="form-label">
                    <i class="fas fa-dumbbell"></i>
                    Tipo de Entrenamiento
                </label>
                <div class="tipo-cards">
                    <div class="tipo-card">
                        <input 
                            type="radio" 
                            name="tipo" 
                            value="Fuerza" 
                            id="tipo-fuerza"
                            <%= routine && routine.tipo === 'Fuerza' ? 'checked' : (!routine ? 'checked' : '') %>
                        >
                        <label for="tipo-fuerza" class="tipo-label">
                            <i class="fas fa-dumbbell tipo-icon"></i>
                            <span class="tipo-name">Fuerza</span>
                        </label>
                    </div>
                    
                    <div class="tipo-card">
                        <input 
                            type="radio" 
                            name="tipo" 
                            value="Cardio" 
                            id="tipo-cardio"
                            <%= routine && routine.tipo === 'Cardio' ? 'checked' : '' %>
                        >
                        <label for="tipo-cardio" class="tipo-label">
                            <i class="fas fa-running tipo-icon"></i>
                            <span class="tipo-name">Cardio</span>
                        </label>
                    </div>
                    
                    <div class="tipo-card">
                        <input 
                            type="radio" 
                            name="tipo" 
                            value="HIIT" 
                            id="tipo-hiit"
                            <%= routine && routine.tipo === 'HIIT' ? 'checked' : '' %>
                        >
                        <label for="tipo-hiit" class="tipo-label">
                            <i class="fas fa-fire tipo-icon"></i>
                            <span class="tipo-name">HIIT</span>
                        </label>
                    </div>
                    
                    <div class="tipo-card">
                        <input 
                            type="radio" 
                            name="tipo" 
                            value="Funcional" 
                            id="tipo-funcional"
                            <%= routine && routine.tipo === 'Funcional' ? 'checked' : '' %>
                        >
                        <label for="tipo-funcional" class="tipo-label">
                            <i class="fas fa-heartbeat tipo-icon"></i>
                            <span class="tipo-name">Funcional</span>
                        </label>
                    </div>
                    
                    <div class="tipo-card">
                        <input 
                            type="radio" 
                            name="tipo" 
                            value="Movilidad" 
                            id="tipo-movilidad"
                            <%= routine && routine.tipo === 'Movilidad' ? 'checked' : '' %>
                        >
                        <label for="tipo-movilidad" class="tipo-label">
                            <i class="fas fa-spa tipo-icon"></i>
                            <span class="tipo-name">Movilidad</span>
                        </label>
                    </div>
                </div>
            </div>
            
            <!-- Duración y Ejercicios -->
            <div class="form-grid">
                <div class="form-group">
                    <label class="form-label">
                        <i class="far fa-clock"></i>
                        Duración (minutos)
                    </label>
                    <input 
                        type="number" 
                        name="duracion" 
                        class="form-input" 
                        value="<%= routine ? routine.duracion : '' %>"
                        placeholder="0" 
                        min="5"
                        max="240"
                        required
                    >
                </div>
                
                <div class="form-group">
                    <label class="form-label">
                        <i class="fas fa-list-ol"></i>
                        Número de Ejercicios
                    </label>
                    <input 
                        type="number" 
                        name="ejercicios_count" 
                        class="form-input" 
                        value="<%= routine ? routine.ejercicios_count : '' %>"
                        placeholder="0" 
                        min="1"
                        max="50"
                        required
                    >
                </div>
            </div>
            
            <!-- Nivel de Dificultad -->
            <div class="form-group full-width">
                <label class="form-label">
                    <i class="fas fa-chart-line"></i>
                    Nivel de Dificultad
                </label>
                <div class="nivel-selector">
                    <div class="nivel-option">
                        <input 
                            type="radio" 
                            name="nivel" 
                            value="Principiante" 
                            id="nivel-principiante"
                            <%= routine && routine.nivel === 'Principiante' ? 'checked' : (!routine ? 'checked' : '') %>
                        >
                        <label for="nivel-principiante" class="nivel-label">Principiante</label>
                    </div>
                    
                    <div class="nivel-option">
                        <input 
                            type="radio" 
                            name="nivel" 
                            value="Intermedio" 
                            id="nivel-intermedio"
                            <%= routine && routine.nivel === 'Intermedio' ? 'checked' : '' %>
                        >
                        <label for="nivel-intermedio" class="nivel-label">Intermedio</label>
                    </div>
                    
                    <div class="nivel-option">
                        <input 
                            type="radio" 
                            name="nivel" 
                            value="Avanzado" 
                            id="nivel-avanzado"
                            <%= routine && routine.nivel === 'Avanzado' ? 'checked' : '' %>
                        >
                        <label for="nivel-avanzado" class="nivel-label">Avanzado</label>
                    </div>
                </div>
            </div>
            
            <!-- Actions -->
            <div class="form-actions">
                <a href="/routines" class="btn-cancel">
                    <i class="fas fa-times"></i>
                    Cancelar
                </a>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-<%= action === 'create' ? 'plus' : 'save' %>"></i>
                    <%= action === 'create' ? 'Crear Rutina' : 'Guardar Cambios' %>
                </button>
            </div>
        </form>
    </div>
</body>
</html>