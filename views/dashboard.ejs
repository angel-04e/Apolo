<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apolo | Panel principal</title>
    <link rel="icon" type="image/png" href="public/images/capr.png">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/a2d9d6bd3c.js" crossorigin="anonymous"></script>
    <style>
        :root {
            --color-dark-bg: #0a0e12;
            --color-dark-secondary: #12181f;
            --color-gold: #b8996e;
            --color-gold-light: #c9a97a;
            --color-gold-dim: #8a7252;
            --color-light-text: #b8bcc4;
            --color-gray: #6b7280;
            --color-gray-light: #8b92a0;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Montserrat', sans-serif;
            background: #000000;
            color: var(--color-light-text);
            min-height: 100vh;
            overflow-x: hidden;
            padding: 0;
            position: relative;
        }
        
        /* Partículas de fondo animadas */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }
        
        .particle {
            position: absolute;
            width: 2px;
            height: 2px;
            background: var(--color-gold);
            border-radius: 50%;
            animation: float 15s infinite;
            opacity: 0.3;
        }
        
        @keyframes float {
            0%, 100% {
                transform: translateY(0) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.3;
            }
            90% {
                opacity: 0.3;
            }
            100% {
                transform: translateY(-100vh) translateX(50px);
                opacity: 0;
            }
        }
        
        .dashboard-wrapper {
            max-width: 100%;
            width: 100%;
            min-height: 100vh;
            margin: 0;
            background: 
                radial-gradient(circle at 10% 20%, rgba(184, 153, 110, 0.08) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(184, 153, 110, 0.05) 0%, transparent 40%),
                linear-gradient(135deg, rgba(10, 14, 18, 0.98), rgba(18, 24, 31, 0.95));
            padding: 30px 50px;
            position: relative;
            z-index: 1;
        }
        
        /* HEADER */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 50px;
            padding: 30px;
            background: rgba(18, 24, 31, 0.6);
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            backdrop-filter: blur(10px);
            position: relative;
            overflow: hidden;
            animation: slideDown 0.8s ease;
        }
        
        .dashboard-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(184, 153, 110, 0.1), transparent);
            animation: shine 3s infinite;
        }
        
        @keyframes shine {
            0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
            100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
        }
        
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-50px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .logo-section {
            display: flex;
            align-items: center;
            gap: 20px;
            position: relative;
            z-index: 2;
        }
        
        .logo-text {
            font-family: 'Playfair Display', serif;
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: 0.3em;
            background: linear-gradient(180deg, #ffffff 0%, #c9a97a 40%, #b8996e 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 30px rgba(184, 153, 110, 0.5);
            animation: glow 2s ease-in-out infinite alternate;
        }
        
        @keyframes glow {
            from {
                filter: drop-shadow(0 0 5px rgba(184, 153, 110, 0.5));
            }
            to {
                filter: drop-shadow(0 0 20px rgba(184, 153, 110, 0.8));
            }
        }
        
        .logo-bolt {
            font-size: 3.5rem;
            color: var(--color-gold);
            filter: drop-shadow(0 0 20px rgba(184, 153, 110, 0.8));
            animation: pulse 2s ease-in-out infinite;
        }
        
        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        .welcome-section {
            text-align: right;
            position: relative;
            z-index: 2;
        }
        
        .welcome-text {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            color: var(--color-gold-light);
            letter-spacing: 0.08em;
            margin-bottom: 8px;
            animation: fadeIn 1s ease 0.3s both;
        }
        
        .welcome-subtitle {
            font-size: 1rem;
            color: var(--color-gray-light);
            letter-spacing: 0.2em;
            text-transform: uppercase;
            animation: fadeIn 1s ease 0.5s both;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateX(20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        /* HERO SECTION */
        .hero-section {
            position: relative;
            margin-bottom: 50px;
            height: 450px;
            border: 2px solid var(--color-gold);
            border-radius: 25px;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.9), rgba(10, 14, 18, 0.95));
            box-shadow: 
                0 20px 60px rgba(0, 0, 0, 0.5),
                inset 0 0 40px rgba(184, 153, 110, 0.1),
                0 0 40px rgba(184, 153, 110, 0.3);
            animation: heroEntry 1s ease 0.5s both;
            cursor: pointer;
            transition: all 0.5s ease;
        }
        
        .hero-section:hover {
            transform: scale(1.02);
            box-shadow: 
                0 30px 80px rgba(0, 0, 0, 0.7),
                inset 0 0 50px rgba(184, 153, 110, 0.2),
                0 0 60px rgba(184, 153, 110, 0.5);
        }
        
        @keyframes heroEntry {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        
        .hero-image {
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: center;
            filter: grayscale(30%) brightness(0.85) contrast(1.2);
            opacity: 0.9;
            padding: 30px;
            transition: all 0.5s ease;
        }
        
        .hero-section:hover .hero-image {
            filter: grayscale(10%) brightness(1) contrast(1.3);
            opacity: 1;
            transform: scale(1.05);
        }
        
        .hero-overlay {
            position: absolute;
            bottom: 30px;
            right: 40px;
            background: rgba(10, 14, 18, 0.95);
            border: 2px solid var(--color-gold);
            padding: 20px 40px;
            border-radius: 15px;
            backdrop-filter: blur(20px);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
            animation: slideUp 1s ease 1s both;
        }
        
        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .hero-quote {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--color-gold);
            font-style: italic;
            letter-spacing: 0.08em;
            text-shadow: 0 0 10px rgba(184, 153, 110, 0.5);
        }
        
        /* STATS GRID */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            margin-bottom: 50px;
        }
        
        .stat-box {
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.8), rgba(10, 14, 18, 0.95));
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }
        
        .stat-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(184, 153, 110, 0.2), transparent);
            transition: left 0.5s;
        }
        
        .stat-box:hover::before {
            left: 100%;
        }
        
        .stat-box:hover {
            transform: translateY(-10px) scale(1.05);
            border-color: var(--color-gold);
            box-shadow: 0 20px 40px rgba(184, 153, 110, 0.4);
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.95), rgba(10, 14, 18, 1));
        }
        
        .stat-box h3 {
            font-size: 0.9rem;
            color: var(--color-gray-light);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 20px;
            font-weight: 500;
        }
        
        .stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 3rem;
            color: var(--color-gold);
            font-weight: 700;
            text-shadow: 0 0 20px rgba(184, 153, 110, 0.5);
            transition: all 0.3s ease;
        }
        
        .stat-box:hover .stat-value {
            transform: scale(1.1);
            color: var(--color-gold-light);
        }
        
        .stat-icon {
            font-size: 2rem;
            color: var(--color-gold-dim);
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }
        
        .stat-box:hover .stat-icon {
            color: var(--color-gold);
            transform: rotateY(360deg);
        }
        
        /* NAVIGATION GRID */
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            margin-bottom: 40px;
        }
        
        .nav-card {
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.7), rgba(10, 14, 18, 0.9));
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            padding: 40px 25px;
            text-decoration: none;
            color: var(--color-light-text);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 20px;
            cursor: pointer;
        }
        
        .nav-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center, rgba(184, 153, 110, 0.2), transparent 70%);
            opacity: 0;
            transition: opacity 0.5s ease;
        }
        
        .nav-card::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(184, 153, 110, 0.1);
            transform: translate(-50%, -50%);
            transition: width 0.6s ease, height 0.6s ease;
        }
        
        .nav-card:hover::before {
            opacity: 1;
        }
        
        .nav-card:hover::after {
            width: 300px;
            height: 300px;
        }
        
        .nav-card:hover {
            transform: translateY(-15px) scale(1.05);
            border-color: var(--color-gold);
            box-shadow: 
                0 25px 50px rgba(184, 153, 110, 0.4),
                inset 0 0 30px rgba(184, 153, 110, 0.1);
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.9), rgba(10, 14, 18, 1));
        }
        
        .nav-icon {
            font-size: 3.5rem;
            color: var(--color-gold);
            transition: all 0.5s ease;
            filter: drop-shadow(0 0 15px rgba(184, 153, 110, 0.5));
            z-index: 2;
        }
        
        .nav-card:hover .nav-icon {
            transform: scale(1.2) rotateY(360deg);
            color: var(--color-gold-light);
            filter: drop-shadow(0 0 25px rgba(184, 153, 110, 0.8));
        }
        
        .nav-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.1rem;
            color: var(--color-gold);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
            margin: 0;
            z-index: 2;
            transition: all 0.3s ease;
        }
        
        .nav-card:hover .nav-title {
            color: var(--color-gold-light);
            transform: scale(1.05);
        }
        
        .nav-subtitle {
            font-size: 0.85rem;
            color: var(--color-gray-light);
            letter-spacing: 0.05em;
            line-height: 1.5;
            z-index: 2;
            transition: all 0.3s ease;
        }
        
        .nav-card:hover .nav-subtitle {
            color: var(--color-light-text);
        }
        
        /* PERFIL SECTION */
        .profile-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 40px;
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.7), rgba(10, 14, 18, 0.9));
            border: 1px solid var(--color-gold-dim);
            border-radius: 20px;
            margin-bottom: 30px;
            transition: all 0.4s ease;
        }
        
        .profile-section:hover {
            border-color: var(--color-gold);
            box-shadow: 0 10px 40px rgba(184, 153, 110, 0.3);
            transform: translateY(-5px);
        }
        
        .profile-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        
        .profile-avatar {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 2px solid var(--color-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: var(--color-gold);
            background: rgba(184, 153, 110, 0.1);
            transition: all 0.3s ease;
        }
        
        .profile-avatar-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 2px solid var(--color-gold);
            object-fit: cover;
            transition: all 0.3s ease;
        }
        
        .profile-section:hover .profile-avatar, .profile-section:hover .profile-avatar-img {
            transform: scale(1.1) rotate(360deg);
            box-shadow: 0 0 20px rgba(184, 153, 110, 0.6);
        }
        
        .profile-text h4 {
            font-size: 1.2rem;
            color: var(--color-gold);
            margin-bottom: 5px;
        }
        
        .profile-text p {
            font-size: 0.85rem;
            color: var(--color-gray-light);
            letter-spacing: 0.1em;
        }
        
        .profile-btn {
            padding: 12px 30px;
            background: linear-gradient(135deg, var(--color-gold-dim), var(--color-gold));
            color: #000;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            letter-spacing: 0.1em;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            font-size: 0.9rem;
        }
        
        .profile-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 30px rgba(184, 153, 110, 0.5);
            background: linear-gradient(135deg, var(--color-gold), var(--color-gold-light));
        }
        
        /* FOOTER QUOTE */
        .footer-quote {
            text-align: center;
            padding: 40px 20px;
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            color: var(--color-gold);
            font-style: italic;
            letter-spacing: 0.1em;
            text-shadow: 0 0 20px rgba(184, 153, 110, 0.5);
            animation: fadeIn 1s ease 1.5s both;
        }
        
        /* RESPONSIVE */
        @media (max-width: 1200px) {
            .nav-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
        
        @media (max-width: 768px) {
            .dashboard-wrapper {
                padding: 20px;
            }
            
            .dashboard-header {
                flex-direction: column;
                text-align: center;
                gap: 20px;
                padding: 20px;
            }
            
            .welcome-section {
                text-align: center;
            }
            
            .logo-text {
                font-size: 2.5rem;
            }
            
            .welcome-text {
                font-size: 1.5rem;
            }
            
            .stats-grid {
                grid-template-columns: 1fr;
            }
            
            .nav-grid {
                grid-template-columns: 1fr;
            }
            
            .hero-section {
                height: 300px;
            }
        }
        
        /* ANIMACIONES DE ENTRADA */
        .stat-box,
        .nav-card {
            animation: fadeInUp 0.6s ease forwards;
            opacity: 0;
        }
        
        .stat-box:nth-child(1) { animation-delay: 1s; }
        .stat-box:nth-child(2) { animation-delay: 1.1s; }
        .stat-box:nth-child(3) { animation-delay: 1.2s; }
        .nav-card:nth-child(1) { animation-delay: 1.3s; }
        .nav-card:nth-child(2) { animation-delay: 1.4s; }
        .nav-card:nth-child(3) { animation-delay: 1.5s; }
        .nav-card:nth-child(4) { animation-delay: 1.6s; }
        
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <!-- Partículas de fondo -->
    <div class="particles" id="particles"></div>
    
    <div class="dashboard-wrapper">
        <!-- HEADER -->
        <div class="dashboard-header">
            <div class="logo-section">
                <span class="logo-text">APOLO</span>
                <i class="fas fa-bolt logo-bolt"></i>
            </div>
            <div class="welcome-section">
                <h1 class="welcome-text">¡Bienvenido, <%= user?.nombre || 'Atleta' %>!</h1>
                <p class="welcome-subtitle">Transformate</p>
            </div>
        </div>
        
        <!-- Imagen Principal -->
        <div class="hero-section">
            <img src="/images/capr.png" 
                 alt="Estatua LE" 
                 class="hero-image"
                 onclick="window.location.href='/destino'">
            
            <div class="hero-overlay">
                <p class="hero-quote">Forja tu Destino</p>
            </div>
        </div>        
        
        <!-- OVERVIEW -->
        <div class="stats-grid">
            <div class="stat-box" onclick="openEnfoqueModal()" style="cursor:pointer">
                <i class="fas fa-bullseye stat-icon"></i>
                <h3>Tu Enfoque Hoy</h3>
                <div class="stat-value" id="enfoque-display"><%= enfoqueHoy || (sugerencia || 'Definir plan') %></div>
            </div>
            <div class="stat-box">
                <i class="far fa-clock stat-icon"></i>
                <h3>Próximo Entrenamiento</h3>
                <% if (proximoEntrenamiento) { %>
                    <div>
                        <div class="stat-value">
                          <%= proximoEntrenamiento.titulo %>
                        </div>
                      
                        <br>
                      
                        <div style="font-size:0.8rem;color:var(--color-gray-light);">
                          <%= new Date(proximoEntrenamiento.fecha_programada)
                          .toLocaleDateString('es-CO', { weekday:'short', month:'short', day:'numeric' })
                          .replace(',', '') %>
                          ·
                          <%= String(proximoEntrenamiento.hora_programada).slice(0,5) %>
                        </div>
                      </div>
                <% } else { %>
                  <div class="stat-value" style="font-size:1rem;color:var(--color-gray-light)">Sin agendar</div>
                  <a href="/routines" style="font-size:0.8rem;color:var(--color-gold);text-decoration:none;margin-top:4px;display:block">+ Añadir rutina</a>
                <% } %>
            </div>
            <div class="stat-box">
                <i class="fas fa-trophy stat-icon"></i>
                <h3>Racha Activa</h3>
                <div class="stat-value">
                    <%= racha %>
                    <span style="font-size:1.2rem">
                      <% if (racha > 0) %>
                    </span>
                </div>
                <div style="font-size:0.75rem;color:var(--color-gray-light);margin-top:4px">
                  <%= racha === 1 ? 'día consecutivo' : racha > 1 ? 'días consecutivos' : 'Comienza hoy' %>
                </div>
            </div>
        </div>
        
        <!-- CARDS -->
        <div class="nav-grid">
            <a href="/routines" class="nav-card">
                <i class="fas fa-dumbbell nav-icon"></i>
                <h3 class="nav-title">Rutinas &<br>Entrenamiento</h3>
                <p class="nav-subtitle">Desarrolla tu Fuerza</p>
            </a>
            
            <a href="/nutrition" class="nav-card">
                <i class="fas fa-leaf nav-icon"></i>
                <h3 class="nav-title">Nutrición<br>& Dieta</h3>
                <p class="nav-subtitle">El Combustible de tu Vida</p>
            </a>
            
            <a href="/habits" class="nav-card">
                <i class="fas fa-book-open nav-icon"></i>
                <h3 class="nav-title">Hábitos &<br>Estilo de Vida</h3>
                <p class="nav-subtitle">Mente y Disciplina</p>
            </a>
            
            <a href="/stats" class="nav-card">
                <i class="fas fa-chart-line nav-icon"></i>
                <h3 class="nav-title">Estadísticas<br>& Progreso</h3>
                <p class="nav-subtitle">Mide tu Transformación</p>
            </a>
        </div>
        
        <!-- Seccion del Perfil -->
        <div class="profile-section">
            <div class="profile-info">
                <% if (user.avatar_url) { %>
                  <img src="<%= user.avatar_url %>" alt="Perfil" class="profile-avatar-img" />
                <% } else { %>
                  <div class="profile-avatar">
                      <i class="fas fa-user"></i>
                  </div>
                <% } %>
                <div class="profile-text">
                    <h4><%= user.nombre || 'Usuario' %></h4>
                    <p>Gestionar Cuenta</p>
                </div>
            </div>
            <button class="profile-btn" onclick="window.location.href='/profile'">
                Ver Perfil
            </button>
        </div>
        
        <div class="footer-quote">
            "Mens sana in corpore sano" 
        </div>
    </div>
    
    <!-- Modal Enfoque -->
    <div id="enfoqueModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.85);z-index:9999;align-items:center;justify-content:center;">
        <div style="background:linear-gradient(135deg,#12181f,#0a0e12);border:2px solid var(--color-gold);border-radius:20px;padding:30px;max-width:450px;width:90%;box-shadow:0 20px 60px rgba(184,153,110,0.3);">
            <h2 style="color:var(--color-gold);font-family:'Playfair Display',serif;margin-bottom:8px;"><i class="fas fa-bullseye"></i> Tu Enfoque Hoy</h2>
            <p style="color:var(--color-gray-light);margin-bottom:20px;font-size:0.9rem;">¿Qué quieres lograr hoy en tu entrenamiento?</p>
            <input type="text" id="enfoqueInput" placeholder="Ej: Series pesadas + alta proteína" 
                style="width:100%;padding:14px 16px;background:rgba(255,255,255,0.05);border:1px solid var(--color-gold-dim);border-radius:10px;color:#fff;font-size:1rem;margin-bottom:20px;">
            <div style="display:flex;gap:12px;justify-content:flex-end;">
                <button onclick="closeEnfoqueModal()" style="padding:12px 24px;background:transparent;border:1px solid var(--color-gray);color:var(--color-gray-light);border-radius:10px;cursor:pointer;">Cancelar</button>
                <button onclick="saveEnfoque()" style="padding:12px 24px;background:var(--color-gold);border:none;color:#000;font-weight:600;border-radius:10px;cursor:pointer;">Guardar</button>
            </div>
        </div>
    </div>
    
    <script>
        // Modal de Enfoque
        const enfoqueModal = document.getElementById('enfoqueModal');
        const enfoqueInput = document.getElementById('enfoqueInput');
        const enfoqueDisplay = document.getElementById('enfoque-display');
        const currentEnfoque = '<%= enfoqueHoy || "" %>';
        const sugerencia = '<%= sugerencia || "" %>';
        
        function openEnfoqueModal() {
            enfoqueInput.value = currentEnfoque || sugerencia || '';
            enfoqueModal.style.display = 'flex';
            enfoqueInput.focus();
        }
        
        function closeEnfoqueModal() {
            enfoqueModal.style.display = 'none';
        }
        
        async function saveEnfoque() {
            const enfoque = enfoqueInput.value.trim();
            if (!enfoque) return;
            
            try {
                const res = await fetch('/dashboard/enfoque', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ enfoque })
                });
                const data = await res.json();
                if (data.success) {
                    enfoqueDisplay.textContent = enfoque;
                    closeEnfoqueModal();
                }
            } catch (e) {
                console.error('Error:', e);
            }
        }
        
        // Cerrar modal al hacer click fuera
        enfoqueModal?.addEventListener('click', (e) => {
            if (e.target === enfoqueModal) closeEnfoqueModal();
        });
        
        // Guardar con Enter
        enfoqueInput?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') saveEnfoque();
        });
        
        // Crear partículas flotantes
        const particlesContainer = document.getElementById('particles');
        for (let i = 0; i < 30; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 15 + 's';
            particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
            particlesContainer.appendChild(particle);
        }
        
        // Efecto de hover en las tarjetas
        const cards = document.querySelectorAll('.nav-card');
        cards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                card.style.setProperty('--mouse-x', x + 'px');
                card.style.setProperty('--mouse-y', y + 'px');
            });
        });
    </script>

</body>
</html>