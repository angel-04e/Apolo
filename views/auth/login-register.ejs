<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apolo - Acceso</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-dark-bg: #0a0e12;
            --color-dark-secondary: #12181f;
            --color-gold: #b8996e;
            --color-gold-light: #c9a97a;
            --color-gold-dim: #8a7252;
            --color-light-text: #b8bcc4;
            --color-gray: #6b7280;
            --color-gray-light: #8b92a0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(180deg, #0a0e12 0%, #12181f 50%, #0a0e12 100%);
            color: var(--color-light-text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
            position: relative;
            padding: 20px;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(circle at 20% 30%, rgba(184, 153, 110, 0.04) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(184, 153, 110, 0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: 1;
        }

        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(184, 153, 110, 0.015) 3px, rgba(184, 153, 110, 0.015) 4px);
            pointer-events: none;
            z-index: 1;
            opacity: 0.4;
        }

        .auth-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            background: linear-gradient(135deg, rgba(18, 24, 31, 0.7), rgba(10, 14, 18, 0.8));
            border: 1px solid rgba(184, 153, 110, 0.15);
            border-radius: 0;
            padding: 50px 40px;
            box-shadow: 
                0 0 50px rgba(0, 0, 0, 0.5),
                0 0 100px rgba(184, 153, 110, 0.08),
                inset 0 0 50px rgba(184, 153, 110, 0.03);
            backdrop-filter: blur(10px);
        }

        .logo-small {
            font-family: 'Playfair Display', serif;
            font-size: 3em;
            font-weight: 600;
            text-align: center;
            letter-spacing: 0.3em;
            text-transform: uppercase;
            margin-bottom: 10px;
            background: linear-gradient(
                180deg,
                #d4d4d4 0%,
                #c9a97a 30%,
                #b8996e 50%,
                #c9a97a 70%,
                #d4d4d4 100%
            );
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            filter: drop-shadow(0 2px 15px rgba(184, 153, 110, 0.2));
        }

        .logo-underline-small {
            width: 100px;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(184, 153, 110, 0.5), transparent);
            margin: 0 auto 40px;
            opacity: 0.6;
        }

        .form-tabs {
            display: flex;
            gap: 0;
            margin-bottom: 35px;
            border-bottom: 1px solid rgba(184, 153, 110, 0.15);
        }

        .tab {
            flex: 1;
            padding: 12px 20px;
            background: transparent;
            border: none;
            color: var(--color-gray);
            font-family: 'Montserrat', sans-serif;
            font-size: 0.95em;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
        }

        .tab::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--color-gold);
            transition: width 0.3s ease;
        }

        .tab.active {
            color: var(--color-gold);
        }

        .tab.active::after {
            width: 100%;
        }

        .tab:hover {
            color: var(--color-gold-light);
        }

        .form-content {
            display: none;
        }

        .form-content.active {
            display: block;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            display: block;
            margin-bottom: 8px;
            color: var(--color-gray-light);
            font-size: 0.9em;
            font-weight: 400;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-input {
            width: 100%;
            padding: 14px 18px;
            background: rgba(18, 24, 31, 0.6);
            border: 1px solid rgba(184, 153, 110, 0.2);
            border-radius: 0;
            color: var(--color-light-text);
            font-family: 'Montserrat', sans-serif;
            font-size: 0.95em;
            transition: all 0.3s ease;
            outline: none;
        }

        .form-input::placeholder {
            color: var(--color-gray);
            opacity: 0.6;
        }

        .form-input:focus {
            border-color: var(--color-gold-dim);
            background: rgba(18, 24, 31, 0.8);
            box-shadow: 0 0 20px rgba(184, 153, 110, 0.1);
        }

        .form-checkbox {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
        }

        .form-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: var(--color-gold-dim);
        }

        .form-checkbox label {
            color: var(--color-gray-light);
            font-size: 0.85em;
            cursor: pointer;
        }

        .submit-btn {
            width: 100%;
            padding: 16px;
            background: transparent;
            border: 1px solid var(--color-gold-dim);
            color: var(--color-gold);
            font-family: 'Montserrat', sans-serif;
            font-size: 1em;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .submit-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(184, 153, 110, 0.2), var(--color-gold-dim));
            transition: left 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: -1;
        }

        .submit-btn:hover::before {
            left: 0;
        }

        .submit-btn:hover {
            color: #ffffff;
            border-color: var(--color-gold);
            box-shadow: 0 0 25px rgba(184, 153, 110, 0.3);
            transform: translateY(-2px);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 30px 0;
            color: var(--color-gray);
            font-size: 0.85em;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(184, 153, 110, 0.2), transparent);
        }

        .social-login {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .social-btn {
            flex: 1;
            padding: 12px;
            background: rgba(18, 24, 31, 0.6);
            border: 1px solid rgba(184, 153, 110, 0.15);
            color: var(--color-gray-light);
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85em;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .social-btn:hover {
            border-color: var(--color-gold-dim);
            background: rgba(18, 24, 31, 0.8);
            color: var(--color-gold-light);
            transform: translateY(-2px);
            box-shadow: 0 0 20px rgba(184, 153, 110, 0.15);
        }

        .forgot-password {
            text-align: right;
            margin-top: -15px;
            margin-bottom: 20px;
        }

        .forgot-password a {
            color: var(--color-gray-light);
            font-size: 0.85em;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .forgot-password a:hover {
            color: var(--color-gold-light);
        }

        .back-link {
            text-align: center;
            margin-top: 30px;
        }

        .back-link a {
            color: var(--color-gray-light);
            font-size: 0.9em;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .back-link a:hover {
            color: var(--color-gold-light);
        }

        @media (max-width: 768px) {
            .auth-container {
                padding: 40px 30px;
            }

            .logo-small {
                font-size: 2.5em;
                letter-spacing: 0.25em;
            }

            .tab {
                font-size: 0.85em;
                padding: 10px 15px;
            }

            .social-login {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <h1 class="logo-small">APOLO</h1>
        <div class="logo-underline-small"></div>

        <div class="form-tabs">
            <button class="tab active" onclick="switchTab('login')">Acceso</button>
            <button class="tab" onclick="switchTab('register')">Registro</button>
        </div>

        <!-- Login Form -->
        <div id="login-form" class="form-content active">
            <form action="/auth/login" method="POST">
                <div class="form-group">
                    <label class="form-label" for="login-email">Email</label>
                    <input 
                        type="email" 
                        id="loginemail" 
                        name="loginemail"
                        class="form-input" 
                        placeholder="tu@email.com"
                        required
                    >
                </div>
            
                <div class="form-group">
                    <label class="form-label" for="login-password">Contraseña</label>
                    <input 
                        type="password" 
                        id="loginpassword" 
                        name="loginpassword"
                        class="form-input" 
                        placeholder="••••••••"
                        required
                    >
                </div>
            
                <div class="forgot-password">
                    <a href="/forgot-password">¿Olvidaste tu contraseña?</a>
                </div>
            
                <div class="form-checkbox">
                    <input type="checkbox" id="remember-me" name="remember">
                    <label for="remember-me">Recordarme</label>
                </div>
            
                <button type="submit" class="submit-btn">Ingresar</button>
            </form>

            <div class="divider">O continúa con</div>

            <div class="social-login">
                <button class="social-btn" onclick="socialLogin('google')">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google
                </button>
                <button class="social-btn" onclick="socialLogin('github')">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                </button>
            </div>
        </div>

        <!-- Register Form -->
        <div id="register-form" class="form-content">
            <form action="/auth/register" method="POST">
                <div class="form-group">
                    <label class="form-label" for="register-name">Nombre</label>
                    <input 
                        type="text" 
                        id="register-name" 
                        name="nombre" 
                        class="form-input" 
                        placeholder="Tu nombre"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="register-email">Email</label>
                    <input 
                        type="email" 
                        id="register-email" 
                        name="email" 
                        class="form-input" 
                        placeholder="tu@email.com"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="register-password">Contraseña</label>
                    <input 
                        type="password" 
                        id="register-password" 
                        name="password" 
                        class="form-input" 
                        placeholder="••••••••"
                        required
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="register-confirm">Confirmar Contraseña</label>
                    <input 
                        type="password" 
                        id="register-confirm" 
                        name="confirmPassword" 
                        class="form-input" 
                        placeholder="••••••••"
                        required
                    >
                </div>

                <div class="form-checkbox">
                    <input type="checkbox" id="terms" name="terms" required>
                    <label for="terms">Acepto los términos y condiciones</label>
                </div>

                <button type="submit" class="submit-btn">Crear Cuenta</button>
            </form>

            <div class="divider">O regístrate con</div>

            <div class="social-login">
                <button class="social-btn" onclick="socialLogin('google')">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google
                </button>
                <button class="social-btn" onclick="socialLogin('github')">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                </button>
            </div>
        </div>

        <div class="back-link">
            <a href="/">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 12H5M12 19l-7-7 7-7"/>
                </svg>
                Volver al inicio
            </a>
        </div>
    </div>

    <script>
        function switchTab(tab) {
            // Cambiar tabs activos
            const tabs = document.querySelectorAll('.tab');
            tabs.forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');

            // Cambiar formularios
            const forms = document.querySelectorAll('.form-content');
            forms.forEach(f => f.classList.remove('active'));
            
            if (tab === 'login') {
                document.getElementById('login-form').classList.add('active');
            } else {
                document.getElementById('register-form').classList.add('active');
            }
        }

        function socialLogin(provider) {
            // funciones de autenticación social
            console.log(`Iniciando sesión con ${provider}`);
        }
    </script>
</body>
</html>